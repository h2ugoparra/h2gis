# h2gis environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── Paths ────────────────────────────────────────────────────────────────────

# Root of the h2gis project (defaults to the package install location).
# Override when running from a cloned repo or a custom location.
H2GIS_ROOT=/path/to/h2gis

# Directory where downloaded datasets are stored.
# Must be an absolute path to a location with sufficient disk space.
STORE_DIR=/path/to/your/data/store

# ── CMEMS (Copernicus Marine Service) ────────────────────────────────────────
# Register at https://data.marine.copernicus.eu/register
# Then run: copernicusmarine login
# Credentials are stored by the copernicusmarine CLI — these env vars are
# only needed if you bypass the CLI login flow.
CMEMS_USERNAME=your_cmems_username
CMEMS_PASSWORD=your_cmems_password

# ── AVISO (Archiving, Validation and Interpretation of Satellite Oceanographic data) ──
# Register at https://www.aviso.altimetry.fr/en/data/data-access/registration-form.html
AVISO_USERNAME=your_aviso_email
AVISO_PASSWORD=your_aviso_password
AVISO_FTP_SERVER=ftp-access.aviso.altimetry.fr
